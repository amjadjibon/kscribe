package templates

import (
	"fmt"
	"net/url"
	"github.com/amjadjibon/kscribe/internal/store"
)

// PhaseBadge renders a coloured phase label.
templ PhaseBadge(phase string) {
	<span class={ "badge", phaseBadgeClass(phase) }>{ phase }</span>
}

// StatCards renders a row of per-phase count cards. Each card links to /?phase=P
// while preserving the other active filter fields (TASK-025).
templ StatCards(totals map[string]int, filter store.IncidentFilter) {
	<div class="stat-cards">
		for _, p := range []string{"Done", "Diagnosing", "Failed", "Partial", "Pending"} {
			<a href={ templ.SafeURL(phaseURL(p, filter)) } class={ "stat-card", phaseCardClass(p), statCardActiveClass(p, filter.Phase) }>
				<span class="stat-card-label">{ p }</span>
				<span class="stat-card-count">{ fmt.Sprintf("%d", totals[p]) }</span>
			</a>
		}
	</div>
}

// IncidentList renders the dashboard list page with filter bar, stat cards, table, and pager.
templ IncidentList(incidents []store.Incident, totals map[string]int, page, lastPage int, filter store.IncidentFilter) {
	<div class="page-header">
		<h2>Incidents</h2>
	</div>
	<!-- Filter bar: GET form so all state lives in the URL (shareable, no JS required). -->
	<!-- CON-005: Alpine x-data on form so @change auto-submits the phase select. -->
	<form action="/" method="GET" class="filter-bar" x-data>
		<input
			type="search"
			name="q"
			value={ filter.Query }
			placeholder="Search name, message, reason…"
			class="filter-input filter-input-wide"
		/>
		<select name="phase" @change="$el.form.submit()" class="filter-select">
			<option value="">All phases</option>
			for _, p := range []string{"Done", "Diagnosing", "Failed", "Partial", "Pending"} {
				<option value={ p } selected?={ filter.Phase == p }>{ p }</option>
			}
		</select>
		<input type="text" name="namespace" value={ filter.Namespace } placeholder="Namespace" class="filter-input"/>
		<input type="text" name="reason" value={ filter.Reason } placeholder="Reason" class="filter-input"/>
		<button type="submit" class="filter-submit">Search</button>
		if filter != (store.IncidentFilter{}) {
			<a href="/" class="filter-clear">Clear</a>
		}
	</form>
	@StatCards(totals, filter)
	if len(incidents) == 0 && page == 1 {
		<div class="empty-state">
			<p>No incidents yet.</p>
		</div>
	} else {
		<table>
			<thead>
				<tr>
					<th>Namespace / Name</th>
					<th>Object</th>
					<th>Reason</th>
					<th>Phase</th>
					<th>Updated</th>
				</tr>
			</thead>
			<tbody>
				for _, inc := range incidents {
					<tr>
						<td>
							<a href={ templ.SafeURL("/incidents/" + inc.Namespace + "/" + inc.Name) } style="font-family: var(--font-mono); font-size: var(--text-sm)">
								{ inc.Namespace }/{ inc.Name }
							</a>
						</td>
						<td style="font-family: var(--font-mono); font-size: var(--text-sm)">{ inc.InvolvedObjectKind }/{ inc.InvolvedObjectName }</td>
						<td>{ inc.Reason }</td>
						<td>@PhaseBadge(inc.Phase)</td>
						<td style="color: var(--c-text-muted); font-size: var(--text-sm)">{ inc.UpdatedAt.Format("2006-01-02 15:04") }</td>
					</tr>
				}
			</tbody>
		</table>
		<div class="pager">
			if page <= 1 {
				<span class="pager-btn disabled">Prev</span>
			} else {
				<a class="pager-btn" href={ templ.SafeURL(pageURL(page-1, filter)) }>Prev</a>
			}
			<span class="pager-label">Page { fmt.Sprintf("%d", page) } of { fmt.Sprintf("%d", lastPage) }</span>
			if page >= lastPage {
				<span class="pager-btn disabled">Next</span>
			} else {
				<a class="pager-btn" href={ templ.SafeURL(pageURL(page+1, filter)) }>Next</a>
			}
		</div>
	}
}

// IncidentDetail renders the full incident detail page with tabbed layout.
// CON-005: tabs use Alpine x-show (not x-if) so the SSE block stays in the DOM.
templ IncidentDetail(d *store.IncidentDetail) {
	<div x-data="{ tab: 'overview' }">
		<div class="detail-header">
			<h2>
				{ d.Namespace }/{ d.Name }
				@PhaseBadge(d.Phase)
			</h2>
		</div>
		<div class="tab-bar" role="tablist">
			<button
				class="tab-button"
				:class="{ 'tab-button-active': tab === 'overview' }"
				@click="tab='overview'"
				role="tab"
			>Overview</button>
			<button
				class="tab-button"
				:class="{ 'tab-button-active': tab === 'rca' }"
				@click="tab='rca'"
				role="tab"
			>RCA</button>
			<button
				class="tab-button"
				:class="{ 'tab-button-active': tab === 'raw' }"
				@click="tab='raw'"
				role="tab"
			>Raw</button>
		</div>
		<!-- Overview tab: event info + SSE live status.
		     x-show keeps this in the DOM so the SSE stream is not interrupted. -->
		<div x-show="tab === 'overview'">
			<section>
				<h3>Event</h3>
				<dl>
					<dt>Object</dt><dd>{ d.InvolvedObjectKind }/{ d.InvolvedObjectName } ({ d.InvolvedObjectNamespace })</dd>
					<dt>Reason</dt><dd>{ d.Reason }</dd>
					<dt>Message</dt><dd>{ d.Message }</dd>
					if d.StartedAt != nil {
						<dt>Started</dt><dd>{ d.StartedAt.Format("2006-01-02 15:04:05 UTC") }</dd>
					}
					if d.CompletedAt != nil {
						<dt>Completed</dt><dd>{ d.CompletedAt.Format("2006-01-02 15:04:05 UTC") }</dd>
					}
					<dt>LLM</dt><dd>{ d.LLMProvider }/{ d.LLMModel } ({ fmt.Sprintf("%d tokens", d.TokensUsed) })</dd>
				</dl>
			</section>
			<section>
				<h3>
					Live Status
					<small style="font-weight:normal;font-size:.7em;color:#888;">(SSE)</small>
				</h3>
				<div
					hx-ext="sse"
					sse-connect={ "/incidents/" + d.Namespace + "/" + d.Name + "/stream" }
					sse-swap="message"
					hx-swap="innerHTML"
					id="live-status"
				>
					@PhaseBadge(d.Phase)
				</div>
			</section>
		</div>
		<!-- RCA tab: diagnosis cards with sanitized Markdown.
		     x-show keeps elements in DOM — Alpine toggles display only. -->
		<div x-show="tab === 'rca'">
			if len(d.Diagnoses) > 0 {
				<section>
					<h3>RCA / Remediation</h3>
					for _, diag := range d.Diagnoses {
						@DiagnosisBlock(diag)
					}
				</section>
			} else {
				<div class="empty-state">
					<p>No diagnosis available yet.</p>
				</div>
			}
		</div>
		<!-- Raw tab: plain key/value dump of event + LLM fields. -->
		<div x-show="tab === 'raw'">
			<section>
				<h3>Raw Fields</h3>
				<dl>
					<dt>Namespace</dt><dd>{ d.Namespace }</dd>
					<dt>Name</dt><dd>{ d.Name }</dd>
					<dt>Phase</dt><dd>{ d.Phase }</dd>
					<dt>Involved Object</dt><dd>{ d.InvolvedObjectKind }/{ d.InvolvedObjectName } ({ d.InvolvedObjectNamespace })</dd>
					<dt>Reason</dt><dd>{ d.Reason }</dd>
					<dt>Message</dt><dd>{ d.Message }</dd>
					<dt>LLM Provider</dt><dd>{ d.LLMProvider }</dd>
					<dt>LLM Model</dt><dd>{ d.LLMModel }</dd>
					<dt>Tokens Used</dt><dd>{ fmt.Sprintf("%d", d.TokensUsed) }</dd>
					if d.StartedAt != nil {
						<dt>Started At</dt><dd>{ d.StartedAt.Format("2006-01-02 15:04:05 UTC") }</dd>
					}
					if d.CompletedAt != nil {
						<dt>Completed At</dt><dd>{ d.CompletedAt.Format("2006-01-02 15:04:05 UTC") }</dd>
					}
					<dt>Created At</dt><dd>{ d.CreatedAt.Format("2006-01-02 15:04:05 UTC") }</dd>
					<dt>Updated At</dt><dd>{ d.UpdatedAt.Format("2006-01-02 15:04:05 UTC") }</dd>
				</dl>
			</section>
		</div>
	</div>
}

// DiagnosisBlock renders a single diagnosis record with sanitized Markdown for LLM fields.
// SEC-001: Summary, RootCause, Remediation go through web.RenderMarkdown (goldmark + bluemonday).
templ DiagnosisBlock(diag store.Diagnosis) {
	<article>
		<header>
			<strong>Diagnosis #{ fmt.Sprintf("%d", diag.ID) }</strong>
			<small style="float:right">{ diag.CreatedAt.Format("2006-01-02 15:04:05") }</small>
		</header>
		<dl>
			if diag.Summary != "" {
				<dt>Summary</dt>
				<dd class="markdown">@RenderMarkdown(diag.Summary)</dd>
			}
			if diag.RootCause != "" {
				<dt>Root Cause</dt>
				<dd class="markdown">@RenderMarkdown(diag.RootCause)</dd>
			}
			if diag.Remediation != "" {
				<dt>Remediation</dt>
				<dd class="markdown">@RenderMarkdown(diag.Remediation)</dd>
			}
			<dt>Confidence</dt>
			<dd>
				<span class="confidence-badge">{ fmt.Sprintf("%.0f%%", diag.Confidence*100) }</span>
			</dd>
		</dl>
	</article>
}

// pageURL builds a pager href preserving all active filter fields. Page 1 is omitted from the URL.
func pageURL(page int, f store.IncidentFilter) string {
	v := url.Values{}
	if page > 1 {
		v.Set("page", fmt.Sprintf("%d", page))
	}
	if f.Phase != "" {
		v.Set("phase", f.Phase)
	}
	if f.Namespace != "" {
		v.Set("namespace", f.Namespace)
	}
	if f.Reason != "" {
		v.Set("reason", f.Reason)
	}
	if f.Query != "" {
		v.Set("q", f.Query)
	}
	if s := v.Encode(); s != "" {
		return "/?" + s
	}
	return "/"
}

// phaseURL builds a stat-card href for phase p while preserving namespace/reason/q.
// Phase is reset to 1 when switching; current page is intentionally dropped.
func phaseURL(phase string, f store.IncidentFilter) string {
	v := url.Values{}
	if phase != "" {
		v.Set("phase", phase)
	}
	if f.Namespace != "" {
		v.Set("namespace", f.Namespace)
	}
	if f.Reason != "" {
		v.Set("reason", f.Reason)
	}
	if f.Query != "" {
		v.Set("q", f.Query)
	}
	if s := v.Encode(); s != "" {
		return "/?" + s
	}
	return "/"
}

// phaseBadgeClass maps a phase string to its CSS class.
func phaseBadgeClass(phase string) string {
	switch phase {
	case "Done":
		return "badge-done"
	case "Partial":
		return "badge-partial"
	case "Failed":
		return "badge-failed"
	case "Diagnosing":
		return "badge-diagnosing"
	default:
		return "badge-pending"
	}
}

// phaseCardClass maps a phase string to its stat-card CSS class.
func phaseCardClass(phase string) string {
	switch phase {
	case "Done":
		return "stat-card-done"
	case "Partial":
		return "stat-card-partial"
	case "Failed":
		return "stat-card-failed"
	case "Diagnosing":
		return "stat-card-diagnosing"
	default:
		return "stat-card-pending"
	}
}

// statCardActiveClass returns the active CSS class when the card's phase matches the current filter.
func statCardActiveClass(phase, activePhase string) string {
	if phase == activePhase {
		return "stat-card-active"
	}
	return ""
}
