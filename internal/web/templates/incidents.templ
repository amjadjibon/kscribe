package templates

import (
	"fmt"
	"net/url"
	"strings"

	"github.com/amjadjibon/kscribe/internal/store"
)

// PhaseBadge renders a coloured phase label.
templ PhaseBadge(phase string) {
	<span class={ "badge", phaseBadgeClass(phase) }>{ phase }</span>
}

// StatCards renders a row of per-phase count cards. Each card links to /?phase=P
// while preserving the other active filter fields (TASK-025).
templ StatCards(totals map[string]int, filter store.IncidentFilter) {
	<div class="stat-cards">
		for _, p := range []string{"Done", "Diagnosing", "Failed", "Partial", "Pending"} {
			<a href={ templ.SafeURL(phaseURL(p, filter)) } class={ "stat-card", phaseCardClass(p), statCardActiveClass(p, filter.Phase) }>
				<span class="stat-card-label">{ p }</span>
				<span class="stat-card-count">{ fmt.Sprintf("%d", totals[p]) }</span>
			</a>
		}
	</div>
}

// IncidentList renders the dashboard list page with filter bar, stat cards, table, and pager.
templ IncidentList(incidents []store.Incident, totals map[string]int, page, lastPage int, filter store.IncidentFilter) {
	<div class="page-header">
		<h2>Incidents</h2>
	</div>
	<!-- Filter bar: GET form so all state lives in the URL (shareable, no JS required). -->
	<!-- CON-005: Alpine x-data on form so @change auto-submits the phase select. -->
	<form action="/" method="GET" class="filter-bar" x-data>
		<input
			type="search"
			name="q"
			value={ filter.Query }
			placeholder="Search name, message, reason…"
			class="filter-input filter-input-wide"
		/>
		<select name="phase" @change="$el.form.submit()" class="filter-select">
			<option value="">All phases</option>
			for _, p := range []string{"Done", "Diagnosing", "Failed", "Partial", "Pending"} {
				<option value={ p } selected?={ filter.Phase == p }>{ p }</option>
			}
		</select>
		<input type="text" name="namespace" value={ filter.Namespace } placeholder="Namespace" class="filter-input"/>
		<input type="text" name="reason" value={ filter.Reason } placeholder="Reason" class="filter-input"/>
		<button type="submit" class="filter-submit">Search</button>
		if filter != (store.IncidentFilter{}) {
			<a href="/" class="filter-clear">Clear</a>
		}
	</form>
	@StatCards(totals, filter)
	if len(incidents) == 0 && page == 1 {
		<div class="empty-state">
			<p>No incidents yet.</p>
		</div>
	} else {
		<table>
			<thead>
				<tr>
					<th>Namespace / Name</th>
					<th>Object</th>
					<th>Reason</th>
					<th>Phase</th>
					<th>Updated</th>
				</tr>
			</thead>
			<tbody>
				for _, inc := range incidents {
					<tr>
						<td>
							<a href={ templ.SafeURL("/incidents/" + inc.Namespace + "/" + inc.Name) } style="font-family: var(--font-mono); font-size: var(--text-sm)">
								{ inc.Namespace }/{ inc.Name }
							</a>
						</td>
							<td class={ "incident-object", missingValueClass(inc.InvolvedObjectKind, inc.InvolvedObjectName) }>{ incidentObjectLabel(inc) }</td>
							<td class={ missingValueClass(inc.Reason) }>{ displayText(inc.Reason, "Not captured") }</td>
						<td>@PhaseBadge(inc.Phase)</td>
						<td style="color: var(--c-text-muted); font-size: var(--text-sm)">{ inc.UpdatedAt.Format("2006-01-02 15:04") }</td>
					</tr>
				}
			</tbody>
		</table>
		<div class="pager">
			if page <= 1 {
				<span class="pager-btn disabled">Prev</span>
			} else {
				<a class="pager-btn" href={ templ.SafeURL(pageURL(page-1, filter)) }>Prev</a>
			}
			<span class="pager-label">Page { fmt.Sprintf("%d", page) } of { fmt.Sprintf("%d", lastPage) }</span>
			if page >= lastPage {
				<span class="pager-btn disabled">Next</span>
			} else {
				<a class="pager-btn" href={ templ.SafeURL(pageURL(page+1, filter)) }>Next</a>
			}
		</div>
	}
}

// IncidentDetail renders the incident detail page with tabs and a persistent chat sidebar.
// CON-005: tabs use Alpine x-show (not x-if) so the SSE block stays in the DOM.
templ IncidentDetail(d *IncidentDetailView) {
	<div class="detail-shell" x-data="{ tab: 'overview', chatOpen: true }" :class="{ 'chat-collapsed': !chatOpen }">
		<main class="detail-main">
			<div class="detail-header">
				<h2>
					{ d.Namespace }/{ d.Name }
					@PhaseBadge(d.Phase)
				</h2>
			</div>
			<div class="tab-bar" role="tablist">
				<button
					class="tab-button"
					:class="{ 'tab-button-active': tab === 'overview' }"
					@click="tab='overview'"
					role="tab"
				>Overview</button>
				<button
					class="tab-button"
					:class="{ 'tab-button-active': tab === 'rca' }"
					@click="tab='rca'"
					role="tab"
				>RCA</button>
				<button
					class="tab-button"
					:class="{ 'tab-button-active': tab === 'context' }"
					@click="tab='context'"
					role="tab"
				>Context</button>
				<button
					class="tab-button"
					:class="{ 'tab-button-active': tab === 'reasoning' }"
					@click="tab='reasoning'"
					role="tab"
				>Reasoning</button>
				<button
					class="tab-button"
					:class="{ 'tab-button-active': tab === 'raw' }"
					@click="tab='raw'"
					role="tab"
				>Raw</button>
			</div>
		<!-- Overview tab: event info + SSE live status.
		     x-show keeps this in the DOM so the SSE stream is not interrupted. -->
		<div x-show="tab === 'overview'">
			<section>
				<h3>Event</h3>
				<dl>
					<dt>Object</dt><dd class={ missingValueClass(d.InvolvedObjectKind, d.InvolvedObjectName) }>{ incidentObjectLabel(d.Incident) }</dd>
					<dt>Reason</dt><dd class={ missingValueClass(d.Reason) }>{ displayText(d.Reason, "Not captured") }</dd>
					<dt>Message</dt><dd class={ missingValueClass(d.Message) }>{ displayText(d.Message, "Not captured") }</dd>
					if d.StartedAt != nil {
						<dt>Started</dt><dd>{ d.StartedAt.Format("2006-01-02 15:04:05 UTC") }</dd>
					}
					if d.CompletedAt != nil {
						<dt>Completed</dt><dd>{ d.CompletedAt.Format("2006-01-02 15:04:05 UTC") }</dd>
					}
					<dt>LLM</dt><dd>{ d.LLMProvider }/{ d.LLMModel } ({ fmt.Sprintf("%d tokens", d.TokensUsed) })</dd>
				</dl>
			</section>
			<section>
				<h3>
					Live Status
					<small style="font-weight:normal;font-size:.7em;color:#888;">(SSE)</small>
				</h3>
				<div
					hx-ext="sse"
					sse-connect={ "/incidents/" + d.Namespace + "/" + d.Name + "/stream" }
					sse-swap="message"
					hx-swap="innerHTML"
					id="live-status"
				>
					@PhaseBadge(d.Phase)
				</div>
			</section>
		</div>
		<!-- RCA tab: diagnosis cards with sanitized Markdown.
		     x-show keeps elements in DOM — Alpine toggles display only. -->
		<div x-show="tab === 'rca'">
			if len(d.DiagnosisViews) > 0 {
				<section>
					<h3>RCA / Remediation</h3>
					for _, dv := range d.DiagnosisViews {
						@DiagnosisBlock(dv.Diagnosis)
					}
				</section>
			} else {
				<div class="empty-state">
					<p>No diagnosis available yet.</p>
				</div>
			}
		</div>
		<!-- Context tab: snapshot decoded from context_json — pod logs, events, node conditions. -->
		<div x-show="tab === 'context'">
			if len(d.DiagnosisViews) > 0 {
				for _, dv := range d.DiagnosisViews {
					@DiagnosisContextBlock(dv)
				}
			} else {
				<div class="empty-state">
					<p>No context captured.</p>
				</div>
			}
		</div>
		<!-- Reasoning tab: LLM reasoning (sanitized Markdown) + tool-call trace. -->
		<div x-show="tab === 'reasoning'">
			if len(d.DiagnosisViews) > 0 {
				for _, dv := range d.DiagnosisViews {
					@DiagnosisReasoningBlock(dv)
				}
			} else {
				<div class="empty-state">
					<p>No reasoning captured.</p>
				</div>
			}
		</div>
		<!-- Raw tab: plain key/value dump of event + LLM fields. -->
		<div x-show="tab === 'raw'">
			<section>
				<h3>Raw Fields</h3>
				<dl>
					<dt>Namespace</dt><dd>{ d.Namespace }</dd>
					<dt>Name</dt><dd>{ d.Name }</dd>
					<dt>Phase</dt><dd>{ d.Phase }</dd>
					<dt>Involved Object</dt><dd class={ missingValueClass(d.InvolvedObjectKind, d.InvolvedObjectName) }>{ incidentObjectLabel(d.Incident) }</dd>
					<dt>Reason</dt><dd class={ missingValueClass(d.Reason) }>{ displayText(d.Reason, "Not captured") }</dd>
					<dt>Message</dt><dd class={ missingValueClass(d.Message) }>{ displayText(d.Message, "Not captured") }</dd>
					<dt>LLM Provider</dt><dd>{ d.LLMProvider }</dd>
					<dt>LLM Model</dt><dd>{ d.LLMModel }</dd>
					<dt>Tokens Used</dt><dd>{ fmt.Sprintf("%d", d.TokensUsed) }</dd>
					if d.StartedAt != nil {
						<dt>Started At</dt><dd>{ d.StartedAt.Format("2006-01-02 15:04:05 UTC") }</dd>
					}
					if d.CompletedAt != nil {
						<dt>Completed At</dt><dd>{ d.CompletedAt.Format("2006-01-02 15:04:05 UTC") }</dd>
					}
					<dt>Created At</dt><dd>{ d.CreatedAt.Format("2006-01-02 15:04:05 UTC") }</dd>
					<dt>Updated At</dt><dd>{ d.UpdatedAt.Format("2006-01-02 15:04:05 UTC") }</dd>
				</dl>
			</section>
			</div>
		</main>
		<aside class="detail-sidebar" :class="{ 'detail-sidebar-collapsed': !chatOpen }" aria-label="Incident chat">
			@ChatPanel(d)
		</aside>
	</div>
}

// ChatPanel renders history + live SSE streaming + input form.
// SEC-001: assistant content goes through RenderMarkdown.
templ ChatPanel(d *IncidentDetailView) {
	<section class="chat-panel" x-data="{ chatDraft: '', chatPending: [], chatSending: false }">
		<button class="chat-rail-button" type="button" x-show="!chatOpen" @click="chatOpen = true" aria-label="Open chat">Chat</button>
		<header class="chat-header" x-show="chatOpen">
			<div>
				<h3>Incident Chat</h3>
				<p>Context-aware RCA assistant</p>
			</div>
			<button class="chat-icon-button" type="button" @click="chatOpen = false" aria-label="Collapse chat" title="Collapse chat">&gt;</button>
		</header>
		<div class="chat-messages" id="chat-messages" x-ref="chatTranscript" x-show="chatOpen" aria-live="polite">
			<div class="chat-history">
				if len(d.ChatMessages) == 0 {
					<div class="chat-empty">
						<strong>Ready for incident follow-up.</strong>
						<span>Ask for blast radius, next command, or remediation checks.</span>
					</div>
				} else {
					for _, msg := range d.ChatMessages {
						if msg.Role == "user" {
							<div class="chat-message chat-message-user">
								<div class="chat-message-label">You</div>
								<div class="chat-bubble chat-bubble-user">{ msg.Content }</div>
							</div>
						} else {
							<div class="chat-message chat-message-assistant">
								<div class="chat-message-label">kscribe</div>
								<div class="chat-bubble chat-bubble-assistant markdown">@RenderMarkdown(msg.Content)</div>
							</div>
						}
					}
				}
			</div>
			<div class="chat-pending">
				<template x-for="(m, i) in chatPending" :key="i">
					<div class="chat-message chat-message-user">
						<div class="chat-message-label">You</div>
						<div class="chat-bubble chat-bubble-user" x-text="m"></div>
					</div>
				</template>
			</div>
			<div class="chat-message chat-message-assistant chat-streaming-message">
				<div class="chat-message-label">kscribe</div>
				<div
					hx-ext="sse"
					sse-connect={ "/incidents/" + d.Namespace + "/" + d.Name + "/chat/stream" }
					sse-swap="message"
					hx-swap="innerHTML"
					id="chat-stream"
					x-ref="chatStream"
					class="chat-bubble chat-bubble-assistant chat-streaming markdown"
				></div>
			</div>
			<template x-if="chatSending && chatPending.length > 0">
				<div class="chat-message chat-message-assistant chat-waiting">
					<div class="chat-message-label">kscribe</div>
					<div class="chat-bubble chat-bubble-assistant">
						<span class="chat-typing-dot"></span>
						<span class="chat-typing-dot"></span>
						<span class="chat-typing-dot"></span>
					</div>
				</div>
			</template>
		</div>
		<div class="chat-input-area" x-show="chatOpen">
			<form
				class="chat-form"
				hx-post={ "/incidents/" + d.Namespace + "/" + d.Name + "/chat" }
				hx-swap="none"
				@submit="if (chatDraft.trim() === '') { $event.preventDefault() } else { chatPending.push(chatDraft); chatSending = true; if ($refs.chatStream) { $refs.chatStream.innerHTML = ''; } $nextTick(() => { if ($refs.chatTranscript) { $refs.chatTranscript.scrollTop = $refs.chatTranscript.scrollHeight } }) }"
				hx-on--after-request="chatSending = false; if (event.detail.successful) { chatDraft = ''; chatPending = []; window.location.reload(); }"
			>
				<input
					type="text"
					name="message"
					x-model="chatDraft"
					placeholder="Ask about this incident..."
					class="chat-input"
					autocomplete="off"
					:disabled="chatSending"
				/>
				<button type="submit" class="chat-send" aria-label="Send message" title="Send message" :disabled="chatSending || chatDraft.trim() === ''">
					<span x-show="!chatSending">↑</span>
					<span x-show="chatSending">...</span>
				</button>
			</form>
			<p class="chat-hint" x-show="!chatSending">Uses the latest diagnosis, context snapshot, and recent chat turns.</p>
			<p class="chat-hint" x-show="chatSending">Streaming response...</p>
		</div>
	</section>
}
// DiagnosisContextBlock renders the decoded snapshot for one diagnosis.
// SEC-001: all values are templ text nodes — HTML-escaped automatically.
templ DiagnosisContextBlock(dv DiagnosisView) {
	<article class="context-block">
		<header>
			<strong>Diagnosis #{ fmt.Sprintf("%d", dv.ID) } — Context</strong>
		</header>
		if dv.Snapshot == nil {
			<div class="empty-state"><p>No context captured.</p></div>
		} else {
			if len(dv.Snapshot.PodContexts) > 0 {
				<section>
					<h4>Pod Logs</h4>
					for _, pod := range dv.Snapshot.PodContexts {
						<div class="context-section">
							<strong>{ pod.PodName }</strong>
							<small> ({ pod.Phase } on { pod.NodeName })</small>
							for _, log := range pod.Logs {
								<div class="log-label">{ log.ContainerName }</div>
								<pre class="log-block">{ log.Lines }</pre>
							}
						</div>
					}
				</section>
			}
			if len(dv.Snapshot.RelatedEvents) > 0 {
				<section>
					<h4>Related Events</h4>
					<table>
						<thead>
							<tr><th>Name</th><th>Reason</th><th>Message</th><th>Count</th></tr>
						</thead>
						<tbody>
							for _, ev := range dv.Snapshot.RelatedEvents {
								<tr>
									<td>{ ev.Name }</td>
									<td>{ ev.Reason }</td>
									<td>{ ev.Message }</td>
									<td>{ fmt.Sprintf("%d", ev.Count) }</td>
								</tr>
							}
						</tbody>
					</table>
				</section>
			}
			if len(dv.Snapshot.NodeConditions) > 0 {
				<section>
					<h4>Node Conditions</h4>
					<dl>
						for _, nc := range dv.Snapshot.NodeConditions {
							<dt>{ nc.NodeName } / { nc.Type }</dt>
							<dd>{ nc.Status } — { nc.Message }</dd>
						}
					</dl>
				</section>
			}
			if dv.Snapshot.DeploymentStatus != nil {
				<section>
					<h4>Deployment: { dv.Snapshot.DeploymentStatus.Name }</h4>
					<dl>
						<dt>Replicas</dt><dd>{ fmt.Sprintf("%d ready / %d available / %d total", dv.Snapshot.DeploymentStatus.ReadyReplicas, dv.Snapshot.DeploymentStatus.AvailableReplicas, dv.Snapshot.DeploymentStatus.Replicas) }</dd>
						for _, c := range dv.Snapshot.DeploymentStatus.Conditions {
							<dt>Condition</dt><dd>{ c }</dd>
						}
					</dl>
				</section>
			}
			if dv.Snapshot.ReplicaSetStatus != nil {
				<section>
					<h4>ReplicaSet: { dv.Snapshot.ReplicaSetStatus.Name }</h4>
					<dl>
						<dt>Replicas</dt><dd>{ fmt.Sprintf("%d ready / %d total", dv.Snapshot.ReplicaSetStatus.ReadyReplicas, dv.Snapshot.ReplicaSetStatus.Replicas) }</dd>
						for _, c := range dv.Snapshot.ReplicaSetStatus.Conditions {
							<dt>Condition</dt><dd>{ c }</dd>
						}
					</dl>
				</section>
			}
			if len(dv.Snapshot.Partial) > 0 {
				<section>
					<h4>Collection Warnings</h4>
					<ul>
						for _, p := range dv.Snapshot.Partial {
							<li>{ p }</li>
						}
					</ul>
				</section>
			}
		}
	</article>
}

// DiagnosisReasoningBlock renders the LLM reasoning (sanitized Markdown) and tool-call trace.
// SEC-001: reasoning passes through RenderMarkdown (goldmark + bluemonday); trace values are templ text nodes.
templ DiagnosisReasoningBlock(dv DiagnosisView) {
	<article class="context-block">
		<header>
			<strong>Diagnosis #{ fmt.Sprintf("%d", dv.ID) } — Reasoning</strong>
		</header>
		if dv.Reasoning == "" && len(dv.TraceSteps) == 0 {
			<div class="empty-state"><p>No reasoning captured.</p></div>
		} else {
			if dv.Reasoning != "" {
				<section>
					<h4>Analysis</h4>
					<div class="markdown">@RenderMarkdown(dv.Reasoning)</div>
				</section>
			}
			if len(dv.TraceSteps) > 0 {
				<section>
					<h4>Tool Trace</h4>
					<ol class="trace-list">
						for _, step := range dv.TraceSteps {
							<li class="trace-step">
								<span class="trace-tool">{ step.Tool }</span>
								<div class="trace-args"><span class="trace-label">args: </span><code>{ marshalJSON(step.Args) }</code></div>
								<div class="trace-result"><span class="trace-label">result: </span><code>{ marshalJSON(step.Result) }</code></div>
							</li>
						}
					</ol>
				</section>
			}
		}
	</article>
}

// DiagnosisBlock renders a single diagnosis record with sanitized Markdown for LLM fields.
// SEC-001: Summary, RootCause, Remediation go through web.RenderMarkdown (goldmark + bluemonday).
templ DiagnosisBlock(diag store.Diagnosis) {
	<article>
		<header>
			<strong>Diagnosis #{ fmt.Sprintf("%d", diag.ID) }</strong>
			<small style="float:right">{ diag.CreatedAt.Format("2006-01-02 15:04:05") }</small>
		</header>
		<dl>
			if diag.Summary != "" {
				<dt>Summary</dt>
				<dd class="markdown">@RenderMarkdown(diag.Summary)</dd>
			}
			if diag.RootCause != "" {
				<dt>Root Cause</dt>
				<dd class="markdown">@RenderMarkdown(diag.RootCause)</dd>
			}
			if diag.Remediation != "" {
				<dt>Remediation</dt>
				<dd class="markdown">@RenderMarkdown(diag.Remediation)</dd>
			}
			<dt>Confidence</dt>
			<dd>
				<span class="confidence-badge">{ fmt.Sprintf("%.0f%%", diag.Confidence*100) }</span>
			</dd>
		</dl>
	</article>
}

// pageURL builds a pager href preserving all active filter fields. Page 1 is omitted from the URL.
func pageURL(page int, f store.IncidentFilter) string {
	v := url.Values{}
	if page > 1 {
		v.Set("page", fmt.Sprintf("%d", page))
	}
	if f.Phase != "" {
		v.Set("phase", f.Phase)
	}
	if f.Namespace != "" {
		v.Set("namespace", f.Namespace)
	}
	if f.Reason != "" {
		v.Set("reason", f.Reason)
	}
	if f.Query != "" {
		v.Set("q", f.Query)
	}
	if s := v.Encode(); s != "" {
		return "/?" + s
	}
	return "/"
}

// phaseURL builds a stat-card href for phase p while preserving namespace/reason/q.
// Phase is reset to 1 when switching; current page is intentionally dropped.
func phaseURL(phase string, f store.IncidentFilter) string {
	v := url.Values{}
	if phase != "" {
		v.Set("phase", phase)
	}
	if f.Namespace != "" {
		v.Set("namespace", f.Namespace)
	}
	if f.Reason != "" {
		v.Set("reason", f.Reason)
	}
	if f.Query != "" {
		v.Set("q", f.Query)
	}
	if s := v.Encode(); s != "" {
		return "/?" + s
	}
	return "/"
}

// phaseBadgeClass maps a phase string to its CSS class.
func phaseBadgeClass(phase string) string {
	switch phase {
	case "Done":
		return "badge-done"
	case "Partial":
		return "badge-partial"
	case "Failed":
		return "badge-failed"
	case "Diagnosing":
		return "badge-diagnosing"
	default:
		return "badge-pending"
	}
}

// phaseCardClass maps a phase string to its stat-card CSS class.
func phaseCardClass(phase string) string {
	switch phase {
	case "Done":
		return "stat-card-done"
	case "Partial":
		return "stat-card-partial"
	case "Failed":
		return "stat-card-failed"
	case "Diagnosing":
		return "stat-card-diagnosing"
	default:
		return "stat-card-pending"
	}
}

// statCardActiveClass returns the active CSS class when the card's phase matches the current filter.
func statCardActiveClass(phase, activePhase string) string {
	if phase == activePhase {
		return "stat-card-active"
	}
	return ""
}

func incidentObjectLabel(inc store.Incident) string {
	kind := strings.TrimSpace(inc.InvolvedObjectKind)
	name := strings.TrimSpace(inc.InvolvedObjectName)
	ns := strings.TrimSpace(inc.InvolvedObjectNamespace)
	switch {
	case kind != "" && name != "" && ns != "":
		return fmt.Sprintf("%s/%s (%s)", kind, name, ns)
	case kind != "" && name != "":
		return kind + "/" + name
	case name != "":
		return name
	case kind != "":
		return kind
	default:
		return "Not captured"
	}
}

func displayText(value, fallback string) string {
	if strings.TrimSpace(value) == "" {
		return fallback
	}
	return value
}

func missingValueClass(values ...string) string {
	for _, value := range values {
		if strings.TrimSpace(value) != "" {
			return ""
		}
	}
	return "muted-value"
}
